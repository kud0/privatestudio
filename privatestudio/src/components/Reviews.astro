---
const reviews = [
  {
    name: "Constantin Panita",
    review: "Reni es un profesional, hace su trabajo con dedicación y pasión. Sabe cómo entender los deseos del cliente y cumplirlos. Para mí, es el mejor que puedes encontrar en Barcelona. Recomiendo encarecidamente su salón que ofrece el mismo buen servicio para las uñas. Servicio de primera 🇪🇸",
    rating: 5,
    date: "hace un año"
  },
  {
    name: "Luis Bonet",
    review: "Los mejores barberos de Barcelona. Reni siempre ofrece un servicio personalizado y de alta calidad. Siempre se asegura de que haya un buen ambiente. No dudes en visitarlo y probarlo por ti mismo, no te arrepentirás.",
    rating: 5,
    date: "hace un año"
  },
  {
    name: "Guillaume Coveney",
    review: "Entré sin cita para un corte de pelo con Pablo y hizo un gran trabajo. No solo es súper amable, sino también meticuloso. Si viviera en Barcelona, ¡sería mi barbero habitual!",
    rating: 5,
    date: "hace 8 meses"
  },
  {
    name: "Zasha Söderling",
    review: "Increíble como siempre. Gracias Reni por tu atención al detalle, calidad y servicio! Es muy apreciado tener un barbero que pone el esfuerzo extra para asegurarse de que el corte de pelo sea como lo había imaginado. ¡Gran trabajo hermano! 💯",
    rating: 5,
    date: "hace un año"
  },
  {
    name: "Nelson Filipe",
    review: "Lugar muy limpio. Bien organizado. Las citas son puntuales. Los cortes están bien hechos. La línea del cabello es recta. Respetan la voluntad del cliente y hacen exactamente lo que pides.",
    rating: 5,
    date: "hace una semana"
  },
  {
    name: "Thomas RICHTER",
    review: "Solo puedo recomendar visitar esta barbería. La mejor barbería de Barcelona. Reni está muy motivado y se preocupa por todos los detalles. Quiere ver a sus clientes felices. Se convirtió en mi barbero personal.",
    rating: 5,
    date: "hace 8 meses"
  }
];
---

<section id="reviews" class="py-20 bg-wall-texture-light">
  <div class="container mx-auto px-4">
    <div class="text-center mb-20 space-y-3">
      <span class="text-beige-900/60 tracking-[0.4em] text-xs font-bold uppercase block" data-i18n="reviews.label">La voz de Private Studio</span>
      <h2 class="text-5xl md:text-7xl font-black text-black tracking-tighter uppercase leading-none">
        <span data-i18n="reviews.title.1">Opiniones</span> <span class="text-transparent bg-clip-text bg-gradient-to-r from-beige-500 to-black" data-i18n="reviews.title.2">Reales</span>
      </h2>
    </div>
    
    <!-- Mobile view (slider) -->
    <div class="relative md:hidden">
      <div class="overflow-hidden" id="mobile-reviews-container">
        <div class="transition-transform duration-500" id="mobile-reviews-wrapper">
          {reviews.map((review, index) => (
            <div class="mobile-review-slide bg-white p-8 rounded-none shadow-md w-full min-h-[430px] flex flex-col">
              <div class="flex items-start gap-6 h-full">
                <!-- Left: Avatar and name -->
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 rounded-full bg-black text-white flex items-center justify-center text-xl font-bold">
                    {review.name.charAt(0)}
                  </div>
                </div>
                
                <!-- Right: Content -->
                <div class="flex-grow flex flex-col">
                  <div class="flex justify-between items-start mb-2">
                    <div>
                      <h3 class="text-xl font-bold">{review.name}</h3>
                      <p class="text-gray-500">{review.date}</p>
                    </div>
                    <div class="flex">
                      {Array.from({ length: review.rating }).map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-black" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  </div>
                  <p class="text-gray-700 flex-grow">{review.review}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Mobile navigation buttons -->
        <button id="mobile-prev-btn" class="absolute left-0 top-1/2 transform -translate-y-1/2 -translate-x-4 bg-black text-white w-10 h-10 rounded-full flex items-center justify-center focus:outline-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="mobile-next-btn" class="absolute right-0 top-1/2 transform -translate-y-1/2 translate-x-4 bg-black text-white w-10 h-10 rounded-full flex items-center justify-center focus:outline-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
        
        <!-- Mobile indicator dots -->
        <div class="flex justify-center mt-8 space-x-2">
          {reviews.map((_, index) => (
            <button class={`w-3 h-3 rounded-full transition-colors duration-300 focus:outline-none mobile-indicator-dot ${index === 0 ? 'bg-black' : 'bg-beige-300'}`} data-index={index}></button>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Desktop view (grid) -->
    <div class="hidden md:grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {reviews.map((review) => (
        <div class="bg-white p-8 shadow-md">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-full bg-black text-white flex items-center justify-center text-xl font-bold">
              {review.name.charAt(0)}
            </div>
            <div>
              <h3 class="text-xl font-bold">{review.name}</h3>
              <p class="text-sm text-gray-500">{review.date}</p>
            </div>
          </div>
          
          <div class="flex mb-4">
            {Array.from({ length: review.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-black" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          
          <p class="text-gray-700">{review.review}</p>
        </div>
      ))}
    </div>

    <!-- Google Review CTA -->
    <div class="text-center mt-16 pt-10 border-t border-beige-200">
      <div class="flex items-center justify-center gap-1 mb-3">
        {Array.from({ length: 5 }).map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-black" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <p class="text-sm font-bold uppercase tracking-wider text-beige-900/60 mb-2">5.0</p>
      <p class="text-beige-900/70 text-sm mb-5" data-i18n="reviews.cta.text">¿Eres cliente de Private Studio? Déjanos tu opinión</p>
      <a href="https://search.google.com/local/writereview?placeid=ChIJSTi2fwCjpBIRs5IMGyNMj9s" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-black text-white px-8 py-3 font-bold tracking-wider uppercase text-sm hover:bg-gray-800 transition-colors">
        <span data-i18n="reviews.cta.button">Opinar en Google</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Mobile slider functionality
    const mobileSlides = document.querySelectorAll('.mobile-review-slide');
    const mobileDots = document.querySelectorAll('.mobile-indicator-dot');
    const mobilePrevBtn = document.getElementById('mobile-prev-btn');
    const mobileNextBtn = document.getElementById('mobile-next-btn');
    
    let currentMobileIndex = 0;
    
    // Function to show mobile slide at given index
    function showMobileSlide(index) {
      // Hide all slides
      mobileSlides.forEach(slide => {
        slide.classList.add('hidden');
      });
      
      // Show current slide
      mobileSlides[index].classList.remove('hidden');
      
      // Update indicator dots
      mobileDots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove('bg-gray-300');
          dot.classList.add('bg-black');
        } else {
          dot.classList.remove('bg-black');
          dot.classList.add('bg-gray-300');
        }
      });
      
      currentMobileIndex = index;
    }
    
    // Show first mobile slide initially
    if (mobileSlides.length > 0) {
      showMobileSlide(0);
    }
    
    // Previous button click
    mobilePrevBtn?.addEventListener('click', () => {
      const newIndex = (currentMobileIndex - 1 + mobileSlides.length) % mobileSlides.length;
      showMobileSlide(newIndex);
      resetAutoSlideTimer(); // Reset timer when manually navigating
    });
    
    // Next button click
    mobileNextBtn?.addEventListener('click', () => {
      const newIndex = (currentMobileIndex + 1) % mobileSlides.length;
      showMobileSlide(newIndex);
      resetAutoSlideTimer(); // Reset timer when manually navigating
    });
    
    // Indicator dots click
    mobileDots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        showMobileSlide(index);
        resetAutoSlideTimer(); // Reset timer when manually navigating
      });
    });
    
    // Auto slide functionality
    let mobileSlideInterval;
    const slideDelay = 5000; // 5 seconds between slides
    
    function startAutoSlide() {
      mobileSlideInterval = setInterval(() => {
        if (mobileSlides.length > 0) {
          const newIndex = (currentMobileIndex + 1) % mobileSlides.length;
          showMobileSlide(newIndex);
        }
      }, slideDelay);
    }
    
    function resetAutoSlideTimer() {
      clearInterval(mobileSlideInterval);
      startAutoSlide();
    }
    
    // Start auto-sliding
    startAutoSlide();
    
    // Pause auto-advance when hovering over the slider (for desktop touch)
    const mobileContainer = document.getElementById('mobile-reviews-container');
    mobileContainer?.addEventListener('mouseenter', () => {
      clearInterval(mobileSlideInterval);
    });
    
    mobileContainer?.addEventListener('mouseleave', () => {
      startAutoSlide();
    });
    
    // Handle touch events for mobile
    let touchStartX = 0;
    let touchEndX = 0;
    
    mobileContainer?.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
      // Pause auto-sliding when user starts touching
      clearInterval(mobileSlideInterval);
    }, false);
    
    mobileContainer?.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
      // Resume auto-sliding after touch ends
      startAutoSlide();
    }, false);
    
    function handleSwipe() {
      const swipeThreshold = 50; // Minimum pixels to consider a swipe
      if (touchEndX < touchStartX - swipeThreshold) {
        // Swipe left, show next slide
        const newIndex = (currentMobileIndex + 1) % mobileSlides.length;
        showMobileSlide(newIndex);
      } else if (touchEndX > touchStartX + swipeThreshold) {
        // Swipe right, show previous slide
        const newIndex = (currentMobileIndex - 1 + mobileSlides.length) % mobileSlides.length;
        showMobileSlide(newIndex);
      }
    }
  });
</script> 